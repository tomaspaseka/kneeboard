<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <!-- SelfContained passed via Publish-Release.ps1 to work around MAUI restore bug in multi-TFM projects. -->
    <AppxPackageSigningEnabled>true</AppxPackageSigningEnabled>
    <!-- No PDB output → PDBPayload item group stays empty → suppresses the mspdbcmf.exe warning
         from Microsoft.Windows.SDK.BuildTools.MSIX.Packaging.targets that fires when the MSVC
         symbol-conversion tool is absent (not required for sideloaded distribution). -->
    <DebugType>none</DebugType>
  </PropertyGroup>
</Project>
